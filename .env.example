# Copy this file to .env and fill in your real key:
#   cp .env.example .env
#
# Sign up free at https://aistudio.google.com/apikey (no credit card
# required for the free tier), create an API key, and paste it below.
# Only needed for "llm" answer mode -- "extractive" mode works with no key.

GOOGLE_API_KEY=your_key_here
